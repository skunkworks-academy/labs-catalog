{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://skunkworks-academy.github.io/labs-catalog/schema/catalog-entry.schema.json",
  "title": "Skunkworks Academy Catalogue Entry",
  "description": "A single catalogued learning item classified by job role, complexity, duration, industry and technology specialization.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "summary", "jobRoles", "complexity", "durationMinutes", "industries", "specializations", "status"],
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Z]{3}-[0-9A-Z]+$", "description": "Stable catalogue identifier, e.g. LNX-101." },
    "title": { "type": "string", "minLength": 4 },
    "summary": { "type": "string", "minLength": 12 },
    "jobRoles": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "description": "References taxonomy.jobRoles[].id" }
    },
    "complexity": { "type": "string", "description": "References taxonomy.complexityLevels[].id" },
    "durationMinutes": { "type": "integer", "minimum": 5, "maximum": 100000 },
    "industries": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "description": "References taxonomy.industries[].id" }
    },
    "specializations": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "description": "References taxonomy.specializations[].id" }
    },
    "status": { "type": "string", "enum": ["draft", "review", "published", "retired"] }
  }
}
